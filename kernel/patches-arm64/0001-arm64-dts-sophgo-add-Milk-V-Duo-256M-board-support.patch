diff --git a/arch/arm64/boot/dts/sophgo/sg2002-milkv-duo-256m.dts b/arch/arm64/boot/dts/sophgo/sg2002-milkv-duo-256m.dts
new file mode 100644
index 0000000..5e10563
--- /dev/null
+++ b/arch/arm64/boot/dts/sophgo/sg2002-milkv-duo-256m.dts
@@ -0,0 +1,127 @@
+// SPDX-License-Identifier: (GPL-2.0 OR MIT)
+
+/dts-v1/;
+
+#include "sg2000.dtsi"
+
+/ {
+	model = "Milk-V Duo 256M";
+	compatible = "milkv,duo-256m", "sophgo,sg2002", "sophgo,sg2000";
+
+	aliases {
+		i2c1 = &i2c1;
+		i2c2 = &i2c2;
+		i2c3 = &i2c3;
+		mmc0 = &sdhci0;
+		serial0 = &uart0;
+		spi2 = &spi2;
+	};
+
+	chosen {
+		stdout-path = "serial0:115200n8";
+	};
+
+	memory@80000000 {
+		device_type = "memory";
+		reg = <0x0 0x80000000 0x0 0x10000000>;
+	};
+};
+
+&osc {
+	clock-frequency = <25000000>;
+};
+
+&dmac {
+	status = "okay";
+};
+
+&emmc {
+	bus-width = <4>;
+	no-1-8-v;
+	cap-mmc-hw-reset;
+	no-sd;
+	no-sdio;
+	non-removable;
+	status = "okay";
+};
+
+&gmac0 {
+	status = "okay";
+};
+
+&i2c1 {
+	status = "okay";
+};
+
+&i2c2 {
+	status = "okay";
+};
+
+&i2c3 {
+	status = "okay";
+};
+
+&mdio {
+	status = "okay";
+};
+
+&saradc {
+	status = "okay";
+};
+
+&sdhci0 {
+	bus-width = <4>;
+	no-1-8-v;
+	disable-wp;
+	status = "okay";
+};
+
+&sdhci1 {
+	bus-width = <4>;
+	cap-sdio-irq;
+	no-mmc;
+	no-sd;
+	non-removable;
+	status = "okay";
+};
+
+&spi2 {
+	status = "okay";
+};
+
+&uart0 {
+	status = "okay";
+};
+
+&uart1 {
+	status = "okay";
+};
+
+&uart2 {
+	status = "okay";
+};
+
+&uart3 {
+	status = "okay";
+};
+
+&usb {
+	dr_mode = "otg";
+	status = "okay";
+};
+
+&wdt {
+	status = "okay";
+};
+
+/* Best-effort arm64 support: the SG2002 is a RISC-V-only SoC, but this DTB is
+ * built so the arm64 image is complete and boots under QEMU -machine virt
+ * (which supplies its own DTB). The reused riscv peripheral DTS references a
+ * riscv "plic" interrupt controller; provide a stub label so it compiles. */
+/ {
+	plic: interrupt-controller@70000000 {
+		compatible = "sophgo,sg2000-plic", "thead,c900-plic";
+		#interrupt-cells = <2>;
+		interrupt-controller;
+	};
+};
