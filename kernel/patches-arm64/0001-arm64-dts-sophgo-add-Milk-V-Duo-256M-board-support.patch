From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: opencode <opencode@localhost>
Date: Sat, 12 Jul 2026 00:00:00 +0000
Subject: [PATCH] arm64: dts: sophgo: add Milk-V Duo 256M (SG2002) board support

Add arm64 device tree for the Milk-V Duo 256M board based on the
SG2002 SoC. The SG2002 is compatible with SG2000 at the arm64 level,
using the same sg2000.dtsi base with 256MB memory configuration.

Signed-off-by: opencode <opencode@localhost>
---
 .../boot/dts/sophgo/sg2002-milkv-duo-256m.dts | 102 ++++++++++++++++++
 1 file changed, 102 insertions(+)
 create mode 100644 arch/arm64/boot/dts/sophgo/sg2002-milkv-duo-256m.dts

diff --git a/arch/arm64/boot/dts/sophgo/sg2002-milkv-duo-256m.dts b/arch/arm64/boot/dts/sophgo/sg2002-milkv-duo-256m.dts
new file mode 100644
index 000000000000..111111111111
--- /dev/null
+++ b/arch/arm64/boot/dts/sophgo/sg2002-milkv-duo-256m.dts
@@ -0,0 +1,102 @@
+// SPDX-License-Identifier: (GPL-2.0 OR MIT)
+
+/dts-v1/;
+
+#include "sg2000.dtsi"
+
+/ {
+	model = "Milk-V Duo 256M";
+	compatible = "milkv,duo-256m", "sophgo,sg2002", "sophgo,sg2000";
+
+	aliases {
+		i2c1 = &i2c1;
+		i2c2 = &i2c2;
+		i2c3 = &i2c3;
+		mmc0 = &sdhci0;
+		serial0 = &uart0;
+		spi2 = &spi2;
+	};
+
+	chosen {
+		stdout-path = "serial0:115200n8";
+	};
+
+	memory@80000000 {
+		device_type = "memory";
+		reg = <0x0 0x80000000 0x0 0x10000000>;
+	};
+};
+
+&osc {
+	clock-frequency = <25000000>;
+};
+
+&dmac {
+	status = "okay";
+};
+
+&emmc {
+	bus-width = <4>;
+	no-1-8-v;
+	cap-mmc-hw-reset;
+	no-sd;
+	no-sdio;
+	non-removable;
+	status = "okay";
+};
+
+&gmac0 {
+	status = "okay";
+};
+
+&i2c1 {
+	status = "okay";
+};
+
+&i2c2 {
+	status = "okay";
+};
+
+&i2c3 {
+	status = "okay";
+};
+
+&mdio {
+	status = "okay";
+};
+
+&saradc {
+	status = "okay";
+};
+
+&sdhci0 {
+	bus-width = <4>;
+	no-1-8-v;
+	disable-wp;
+	status = "okay";
+};
+
+&sdhci1 {
+	bus-width = <4>;
+	cap-sdio-irq;
+	no-mmc;
+	no-sd;
+	non-removable;
+	status = "okay";
+};
+
+&spi2 {
+	status = "okay";
+};
+
+&uart0 {
+	status = "okay";
+};
+
+&uart1 {
+	status = "okay";
+};
+
+&uart2 {
+	status = "okay";
+};
+
+&uart3 {
+	status = "okay";
+};
+
+&usb {
+	dr_mode = "otg";
+	status = "okay";
+};
+
+&wdt {
+	status = "okay";
+};
-- 
2.34.1

